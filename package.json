{
  "name": "mdd-dashboard",
  "version": "0.1.2",
  "description": "Interactive visual browser dashboard for MDD projects",
  "type": "module",
  "bin": {
    "mdd-dashboard": "bin/mdd-dashboard.js"
  },
  "files": [
    "bin/",
    "dist/",
    "docs/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "open": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
